{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "routes": [
    { "src": "/api/predict",          "dest": "api/predict.py" },
    { "src": "/api/project-stats",    "dest": "api/project_stats.py" },
    { "src": "/api/model-info",       "dest": "api/model_info.py" },
    { "src": "/api/synthetic-sample", "dest": "api/synthetic_sample.py" },
    { "src": "/api/explain",          "dest": "api/explain.py" },
    { "src": "/analytics",            "dest": "public/analytics.html" },
    { "src": "/architecture",         "dest": "public/architecture.html" },
    { "src": "/(.*)",                 "dest": "public/index.html" }
  ],
  "functions": {
    "api/predict.py":  { "memory": 1024, "maxDuration": 30 },
    "api/explain.py":  { "memory": 512,  "maxDuration": 15 },
    "api/*.py":        { "memory": 512,  "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization" }
      ]
    }
  ]
}
